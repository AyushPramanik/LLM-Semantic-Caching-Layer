{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["semantic-cache", "llm", "cost"],
  "title": "LLM Semantic Caching Layer — Overview",
  "uid": "semantic-cache-overview",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Real-time Hit Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "green", "value": 0.5 }
          ] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total[5m])) / clamp_min(sum(rate(cache_hits_total[5m])) + sum(rate(cache_misses_total[5m])), 1)",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Estimated Cost Saved (USD)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "estimated_cost_saved_usd", "legendFormat": "saved", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Tokens Saved",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "expr": "tokens_saved", "legendFormat": "tokens", "refId": "A" } ]
    },
    {
      "id": 4,
      "title": "Cache Growth (entries)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [ { "expr": "cache_size", "legendFormat": "entries", "refId": "A" } ]
    },
    {
      "id": 5,
      "title": "Cache Efficiency Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [ { "expr": "cache_hit_rate", "legendFormat": "hit rate", "refId": "A" } ]
    },
    {
      "id": 6,
      "title": "Cache Lookup Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 5 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(cache_lookup_latency_ms_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(cache_lookup_latency_ms_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(cache_lookup_latency_ms_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 7,
      "title": "Provider Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 5 } } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(provider_latency_ms_bucket[5m])) by (le, provider))", "legendFormat": "{{provider}} p95", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "title": "Similarity Score Distribution",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "options": { "calculate": false, "cellGap": 1, "yAxis": { "unit": "short" } },
      "targets": [
        { "expr": "sum(rate(similarity_distribution_bucket[5m])) by (le)", "format": "heatmap", "legendFormat": "{{le}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "Requests by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 21 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "sum(rate(requests_by_provider[15m])) by (provider)", "legendFormat": "{{provider}}", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "title": "Requests by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 21 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "sum(rate(requests_by_model[15m])) by (model)", "legendFormat": "{{model}}", "refId": "A" }
      ]
    }
  ]
}
